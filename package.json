{
  "name": "beastleague",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "collector",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=client\" \"npm run dev --workspace=server\"",
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npx tsc --noEmit -p tsconfig.base.json",
    "seed": "npx ts-node -P server/tsconfig.json -r tsconfig-paths/register server/src/scripts/seed.ts",
    "e2e": "npx ts-node -P server/tsconfig.json -r tsconfig-paths/register server/src/scripts/e2eFlow.ts",
    "validate-data": "npx ts-node -P collector/tsconfig.json collector/src/tools/validate.ts",
    "add-images": "bash scripts/add-character-images.sh",
    "score": "npx ts-node collector/src/cli/scoreInput.ts",
    "migrate": "npx ts-node -P server/tsconfig.json -r tsconfig-paths/register server/src/scripts/migrate-to-predictions.ts"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}
