# ─────────────────────────────────────────
# 비스트리그 환경변수 예시
# 복사: cp .env.example .env
# .env 파일은 절대 커밋하지 마세요.
# ─────────────────────────────────────────

# ── MongoDB ───────────────────────────────
# 로컬: mongodb://localhost:27017/beastleague
# Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/beastleague
MONGODB_URI=

# ── NextAuth ──────────────────────────────
# openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── OAuth — 카카오 ────────────────────────
# https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=

# ── OAuth — 구글 ─────────────────────────
# https://console.cloud.google.com → API & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── 서버 설정 ─────────────────────────────
PORT=4000
# JWT 서명 키 (openssl rand -base64 32)
JWT_SECRET=
# 내부 API 인증 키 (collector → server 통신용)
INTERNAL_API_KEY=

# ── FCM (선택) ────────────────────────────
# Firebase Console → 프로젝트 설정 → 클라우드 메시징
FCM_SERVER_KEY=

# ── 클라이언트 (Next.js) ──────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000

# ── Collector ─────────────────────────────
# 수동 입력 도구가 데이터를 전송할 서버 주소
API_URL=http://localhost:4000
